        {"id": 4, "command": ["neato", "-Tpng", "-n2", "-Goverlap=false", "-Gsplines=true", "-o", "out.png", "in.gv"], "params": {"T": "png", "n": "2", "G": "overlap=false,splines=true", "o": "out.png", "input": "in.gv"}, "description": "Neato layout with nop mode 2, custom graph attributes"},
