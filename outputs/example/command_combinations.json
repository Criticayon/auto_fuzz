        {"id": 2, "command": ["dot", "-Tsvg", "-Kneato", "-o", "out.svg", "in.gv"], "params": {"T": "svg", "K": "neato", "o": "out.svg", "input": "in.gv"}, "description": "Neato layout to SVG"},
