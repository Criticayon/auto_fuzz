      "name": "dot",
      "entry_file": "cmd/dot/dot.c",
      "description": "Main rendering program for various layouts and output formats. Aliases (symlinks to dot) auto-select layout engine: circo, fdp, neato, osage, patchwork, sfdp, twopi",
      "language": "C",
      "arg_parsing": "gvParseArgs() in lib/common/args.c -> dotneato_args_initialize() in lib/common/input.c",
      "parameters": [
        {"flag": "-T<format>", "type": "arg", "description": "Output format (png, svg, pdf, ps, jpeg, gif, json, dot, xdot, etc.)"},
        {"flag": "-K<layout>", "type": "arg", "description": "Layout engine (dot, neato, fdp, sfdp, twopi, circo, osage, patchwork)"},
        {"flag": "-G<name>=<val>", "type": "arg", "description": "Set graph attribute"},
        {"flag": "-N<name>=<val>", "type": "arg", "description": "Set node attribute"},
        {"flag": "-E<name>=<val>", "type": "arg", "description": "Set edge attribute"},
        {"flag": "-A<name>=<val>", "type": "arg", "description": "Set graph+node+edge attribute"},
        {"flag": "-l<lib>", "type": "arg", "description": "Load plugin library"},
        {"flag": "-o<file>", "type": "arg", "description": "Output file"},
        {"flag": "-O", "type": "flag", "description": "Auto-output filename"},
        {"flag": "-q[lvl]", "type": "opt_arg", "description": "Set warning level (1=AGERR, 2=AGMAX)"},
        {"flag": "-s<scale>", "type": "arg", "description": "Set input scale (points per inch)"},
        {"flag": "-v[lvl]", "type": "opt_arg", "description": "Verbose mode"},
        {"flag": "-x", "type": "flag", "description": "Reduce graph (neato mode)"},
        {"flag": "-y", "type": "flag", "description": "Invert y coordinate"},
        {"flag": "-n[lvl]", "type": "opt_arg", "description": "Neato layout mode (nop)"},
        {"flag": "-L<param>=<val>", "type": "arg", "description": "FDP-specific params: Lg, LO, Lm<n>, Ln<n>, LU, LC<v>, LT<v>"},
        {"flag": "-c", "type": "flag", "description": "Configure plugins (admin only)"},
        {"flag": "-P", "type": "flag", "description": "Generate plugin graph"},
        {"flag": "-V", "type": "flag", "description": "Print version"},
        {"flag": "-?", "type": "flag", "description": "Print usage"},
        {"flag": "--help", "type": "flag", "description": "Print help"},
        {"flag": "--filepath=<path>", "type": "arg", "description": "Set file search path"}
      ],
      "combinations": [
